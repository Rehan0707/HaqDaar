{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://haqdaar.local/schemas/scheme_registry.schema.json",
  "title": "Scheme Registry",
  "type": "object",
  "required": [
    "scheme_id",
    "scheme_name",
    "jurisdiction_type",
    "portability_type",
    "benefit_domain",
    "status",
    "source"
  ],
  "properties": {
    "scheme_id": {
      "type": "string",
      "description": "Stable unique identifier, e.g. CENTRAL_PMAWAS or MH_STATE_XYZ"
    },
    "scheme_name": {
      "type": "string"
    },
    "scheme_short_name": {
      "type": ["string", "null"]
    },
    "jurisdiction_type": {
      "type": "string",
      "enum": ["CENTRAL", "STATE"]
    },
    "state_code": {
      "type": ["string", "null"],
      "description": "Null for central schemes"
    },
    "portability_type": {
      "type": "string",
      "enum": [
        "FULLY_PORTABLE",
        "PORTABLE_WITH_TRANSFER",
        "NOT_PORTABLE_EQUIVALENT_REQUIRED",
        "UNKNOWN"
      ]
    },
    "benefit_domain": {
      "type": "string",
      "enum": [
        "housing",
        "employment",
        "food",
        "health",
        "education",
        "social_security",
        "agriculture",
        "women_child",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "deprecated", "draft"]
    },
    "equivalent_scheme_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_state_code", "target_scheme_id", "mapping_type"],
        "properties": {
          "target_state_code": { "type": "string" },
          "target_scheme_id": { "type": "string" },
          "mapping_type": {
            "type": "string",
            "enum": ["equivalent", "continuation_path", "partial_overlap", "none"]
          },
          "confidence_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "notes": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "source": {
      "type": "object",
      "required": ["source_type", "source_name"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["kaggle", "gov_portal", "manual"]
        },
        "source_name": { "type": "string" },
        "source_url": { "type": ["string", "null"], "format": "uri" },
        "version": { "type": ["string", "null"] },
        "ingested_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "jurisdiction_type": { "const": "STATE" }
        }
      },
      "then": {
        "required": ["state_code"],
        "properties": {
          "state_code": { "type": "string", "minLength": 2 }
        }
      }
    }
  ],
  "additionalProperties": false
}
